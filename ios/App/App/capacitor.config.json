{
	"appId": "com.routinist.app",
	"appName": "Routinist",
	"webDir": "out",
	"server": {
		"androidScheme": "https",
		"iosScheme": "https",
		"allowNavigation": [
			"*.cafe24.com",
			"routinist.cafe24.com",
			"routinist.kr",
			"*.routinist.kr",
			"*.inicis.com",
			"*.nicepay.co.kr",
			"*.kakaopay.com",
			"*.tosspayments.com",
			"*.naverpay.com",
			"*.kftc-bokr.org"
		]
	},
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": true,
			"showSpinner": false,
			"backgroundColor": "#ffffff"
		}
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"FilesystemPlugin",
		"SharePlugin",
		"HealthPlugin"
	]
}
